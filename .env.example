# Flask secret key
SECRET_KEY=change-me

# MongoDB Atlas connection URI
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/?appName=Cluster0
MONGO_DBNAME=lepaix

# Admin login seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional test MongoDB URI
TEST_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/?appName=Cluster0
TEST_MONGO_DBNAME=lepaix_test

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
